page {
  background: #f6f8fb;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #eef2f7;
  box-sizing: border-box;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.muted {
  color: #667085;
  font-size: 26rpx;
}

.primary-btn {
  margin-top: 20rpx;
  background: #1f7ae0;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 600;
}

.sub-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #172033;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #1f7ae0;
  font-size: 24rpx;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
