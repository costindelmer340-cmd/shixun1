.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.form-item:last-of-type {
  border-bottom: 0;
}

.label {
  color: #667085;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

input {
  height: 72rpx;
  font-size: 30rpx;
  color: #101828;
}

.form-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.save-btn,
.secondary-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.save-btn {
  background: #1f7ae0;
  color: #ffffff;
}

.secondary-btn {
  background: #f2f4f7;
  color: #344054;
}

.header-row {
  margin-bottom: 16rpx;
}

.empty-text {
  color: #667085;
  font-size: 26rpx;
  padding: 24rpx 0;
}

.address-card {
  padding: 22rpx 0;
  border-top: 1rpx solid #eef2f7;
}

.address-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #101828;
}

.address-name text {
  margin-left: 16rpx;
  color: #667085;
  font-size: 26rpx;
  font-weight: 400;
}

.address-line {
  margin-top: 10rpx;
  line-height: 1.5;
}

.source-line {
  margin-top: 8rpx;
  color: #1f7ae0;
  font-size: 22rpx;
}

.default-tag {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eaf3ff;
  color: #1f7ae0;
  font-size: 22rpx;
}

.address-actions {
  display: flex;
  gap: 14rpx;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.text-btn,
.danger-btn {
  width: 120rpx;
  height: 54rpx;
  line-height: 54rpx;
  margin: 0;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.text-btn {
  background: #eef4ff;
  color: #1f7ae0;
}

.danger-btn {
  background: #fff1f0;
  color: #d92d20;
}
