<view class="page">
  <view class="card">
    <view class="sub-title">{{editingId ? '编辑地址' : '新增地址'}}</view>
    <view class="form-item">
      <view class="label">联系人</view>
      <input value="{{form.name}}" data-field="name" bindinput="onInput" placeholder="请输入联系人" />
    </view>
    <view class="form-item">
      <view class="label">联系电话</view>
      <input value="{{form.phone}}" data-field="phone" bindinput="onInput" placeholder="请输入联系电话" />
    </view>
    <view class="form-item">
      <view class="label">所在地区</view>
      <input value="{{form.region}}" data-field="region" bindinput="onInput" placeholder="请输入所在地区" />
    </view>
    <view class="form-item">
      <view class="label">详细地址</view>
      <input value="{{form.detail}}" data-field="detail" bindinput="onInput" placeholder="请输入详细地址" />
    </view>
    <view class="form-actions">
      <button wx:if="{{editingId}}" class="secondary-btn" bindtap="resetForm">取消编辑</button>
      <button class="save-btn" bindtap="saveAddress">{{editingId ? '保存修改' : '新增地址'}}</button>
    </view>
  </view>

  <view class="card">
    <view class="between header-row">
      <view class="sub-title">地址列表</view>
      <view class="muted">{{addresses.length}} 个地址</view>
    </view>
    <view wx:if="{{!addresses.length}}" class="empty-text">暂无地址，请先新增联系地址。</view>
    <view wx:for="{{addresses}}" wx:key="id" class="address-card">
      <view class="between">
        <view>
          <view class="address-name">{{item.name}} <text>{{item.phone}}</text></view>
          <view class="muted address-line">{{item.fullAddress}}</view>
          <view wx:if="{{item.source}}" class="source-line">{{item.source}}账号 {{item.sourceAccountNo}} 导入</view>
        </view>
        <view wx:if="{{item.isDefault}}" class="default-tag">默认</view>
      </view>
      <view class="address-actions">
        <button wx:if="{{!item.isDefault}}" class="text-btn" data-id="{{item.id}}" bindtap="setDefault">设为默认</button>
        <button class="text-btn" data-id="{{item.id}}" bindtap="editAddress">编辑</button>
        <button class="danger-btn" data-id="{{item.id}}" bindtap="deleteAddress">删除</button>
      </view>
    </view>
  </view>
</view>
