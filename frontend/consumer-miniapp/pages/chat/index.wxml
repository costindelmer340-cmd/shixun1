<view class="page">
  <view wx:if="{{!platformBound}}" class="empty-card">
    <view class="empty-title">请先绑定电商平台</view>
    <view class="empty-text">绑定平台账号后，客服会根据对应订单进行 AI 或人工对话。</view>
    <button class="empty-btn" bindtap="goBind">去绑定</button>
  </view>

  <block wx:else>
  <view class="consult-order card" bindtap="goOrderDetail">
    <image class="consult-thumb" src="{{consultingOrder.image}}" mode="aspectFill" />
    <view class="consult-info">
      <view class="sub-title">{{consultingOrder.title}}</view>
      <view class="muted">订单编号：{{consultingOrder.no}}</view>
      <view class="muted">商家：{{consultingOrder.merchant}}</view>
      <view class="muted">售后状态：{{consultingOrder.afterSale}}</view>
    </view>
    <view class="consult-arrow">›</view>
  </view>

  <scroll-view class="order-switch" scroll-x>
    <view
      wx:for="{{orders}}"
      wx:key="no"
      data-no="{{item.no}}"
      bindtap="switchOrder"
      class="order-chip {{activeOrderNo === item.no ? 'order-chip-active' : ''}}"
    >
      <image class="chip-thumb" src="{{item.image}}" mode="aspectFill" />
      <view class="chip-text">
        <view>{{item.title}}</view>
        <text>{{item.merchant}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="chat-list">
    <view wx:for="{{messages}}" wx:key="index" class="msg-row {{item.role === 'user' ? 'msg-right' : 'msg-left'}}">
      <view class="speaker">{{item.speaker}} {{item.time}}</view>
      <view class="bubble {{item.role === 'user' ? 'bubble-user' : ''}}">
        {{item.content}}
      </view>
    </view>
  </view>

  <view class="input-card">
    <input value="{{inputValue}}" bindinput="onInput" placeholder="输入消息，发送“转人工”可接入人工客服" />
    <button class="send-btn" bindtap="sendMessage">发送</button>
  </view>
  </block>
</view>
