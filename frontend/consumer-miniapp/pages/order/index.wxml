<view class="page">
  <view class="page-title">我的订单</view>
  
  <view wx:if="{{loading}}">
    <view class="loading">
      <view class="loading-icon"></view>
      <view class="loading-text">加载中...</view>
    </view>
  </view>
  
  <view wx:elif="{{orders.length == 0}}" class="empty-card">
    <view class="empty-title">暂无订单</view>
    <view class="empty-text">绑定平台账号后，这里会同步展示对应订单。</view>
  </view>
  
  <view wx:else>
    <view wx:for="{{orders}}" wx:key="no" class="order-card">
      <image class="product-thumb" src="{{item.image}}" mode="aspectFill" />
      <view class="order-info">
        <view class="between">
          <view class="order-title">{{item.title}}</view>
          <view class="price">￥{{item.price}}</view>
        </view>
        <view class="muted">{{item.platform}} · {{item.status}}</view>
        <view class="order-bottom">
          <view class="tag">售后：{{item.afterSale}}</view>
          <view class="detail-link" bindtap="viewDetail" data-no="{{item.no}}">查看详情 ›</view>
        </view>
      </view>
    </view>
  </view>
</view>
