.page {
  padding-bottom: 150rpx;
}

.profile-card {
  display: flex;
  align-items: center;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 36rpx;
  background: #eaf2ff;
  margin-right: 22rpx;
  flex-shrink: 0;
}

.profile-main {
  flex: 1;
}

.edit-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #1f7ae0;
  font-size: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.info-row:last-child {
  border-bottom: 0;
}

.address {
  margin-top: 10rpx;
  max-width: 560rpx;
}

.arrow {
  color: #98a2b3;
  font-size: 44rpx;
}

.account-actions {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: 70rpx;
  display: flex;
  gap: 18rpx;
  z-index: 5;
}

.logout-btn,
.cancel-account-btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.logout-btn {
  background: #eef4ff;
  color: #1f7ae0;
}

.cancel-account-btn {
  background: #fff1f0;
  color: #d92d20;
}

.dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 42rpx;
  box-sizing: border-box;
  background: rgba(15, 23, 42, 0.42);
}

.cancel-dialog {
  width: 100%;
  padding: 36rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #101828;
  margin-bottom: 18rpx;
}

.dialog-warning {
  color: #d92d20;
  font-size: 27rpx;
  line-height: 1.65;
}

.dialog-hint {
  margin-top: 18rpx;
  color: #667085;
  font-size: 25rpx;
}

.dialog-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.dialog-cancel-btn,
.dialog-confirm-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 14rpx;
  font-size: 27rpx;
}

.dialog-cancel-btn {
  background: #f2f4f7;
  color: #344054;
}

.dialog-confirm-btn {
  background: #d92d20;
  color: #ffffff;
}

.dialog-confirm-disabled {
  background: #f2b8b5;
  color: #ffffff;
}
