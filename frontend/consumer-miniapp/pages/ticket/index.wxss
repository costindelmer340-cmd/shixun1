.container {
  min-height: 100vh;
  background-color: #f6f8fb;
  padding-bottom: 100rpx;
}

.status-tabs {
  display: flex;
  background-color: #ffffff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ebeef5;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #667085;
  padding: 16rpx 0;
  position: relative;
}

.tab-item.active {
  color: #1f7ae0;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #1f7ae0;
  border-radius: 2rpx;
}

.ticket-list {
  padding: 20rpx;
}

.ticket-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.ticket-type {
  font-size: 24rpx;
  color: #ffffff;
  background-color: #1f7ae0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.ticket-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.ticket-status.pending {
  background-color: #fef3c7;
  color: #d97706;
}

.ticket-status.processing {
  background-color: #dbeafe;
  color: #2563eb;
}

.ticket-status.pending_review {
  background-color: #fce7f3;
  color: #db2777;
}

.ticket-status.completed {
  background-color: #dcfce7;
  color: #16a34a;
}

.ticket-status.closed {
  background-color: #f3f4f6;
  color: #6b7280;
}

.ticket-status.rejected {
  background-color: #fee2e2;
  color: #dc2626;
}

.ticket-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.ticket-desc {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ticket-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #9ca3af;
}

.ticket-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f3f4f6;
}

.priority {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.priority.low {
  background-color: #f3f4f6;
  color: #6b7280;
}

.priority.medium {
  background-color: #fef3c7;
  color: #d97706;
}

.priority.high {
  background-color: #fee2e2;
  color: #dc2626;
}

.priority.critical {
  background-color: #fce7f3;
  color: #db2777;
}

.arrow {
  font-size: 32rpx;
  color: #9ca3af;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.action-area {
  flex: 1;
  display: flex;
  justify-content: flex-start;
}

.cancel-btn {
  font-size: 26rpx;
  color: #e74c3c;
  padding: 8rpx 20rpx;
  border: 1rpx solid #e74c3c;
  border-radius: 8rpx;
}