<view class="page">
  <view class="hero card">
    <view class="title">外部电商平台绑定</view>
    <view class="muted">绑定平台账号后，可同步订单并发起售后服务。</view>
  </view>

  <view class="platform-grid">
    <view
      wx:for="{{platforms}}"
      wx:key="name"
      class="platform-card {{item.wide ? 'platform-card-wide' : ''}}"
      bindtap="bindPlatform"
      data-name="{{item.name}}"
    >
      <view class="platform-main">
        <image class="platform-icon" src="{{item.icon}}" mode="aspectFill" />
        <view class="platform-info">
          <view class="sub-title">{{item.name}}</view>
          <view class="muted">{{item.status}}</view>
        </view>
        <button wx:if="{{item.name === '20商城' && !twentyMallBound}}" class="bind-btn" catchtap="bindPlatform" data-name="{{item.name}}">绑定</button>
        <view class="arrow">›</view>
      </view>
      <view wx:if="{{item.name === '20商城' && twentyMallBindings.length}}" class="bound-panel">
        <view class="bound-title">已绑定账号</view>
        <view wx:for="{{twentyMallBindings}}" wx:key="accountNo" class="bound-account">
          <text>{{item.accountNo}}</text>
          <button class="unbind-btn" catchtap="unbindTwentyMall" data-account="{{item.accountNo}}">解绑</button>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{twentyMallDialogVisible}}" class="dialog-mask">
    <view class="dialog">
      <view class="sub-title">绑定20商城账号</view>
      <view class="muted">消费者演示账号：20230140 / 123456</view>
      <input class="dialog-input" placeholder="请输入20商城账号" value="{{twentyMallAccount}}" bindinput="onTwentyMallAccountInput" />
      <input class="dialog-input" password placeholder="请输入密码" value="{{twentyMallPassword}}" bindinput="onTwentyMallPasswordInput" />
      <view class="dialog-actions">
        <button class="cancel-btn" bindtap="closeTwentyMallDialog">取消</button>
        <button class="confirm-btn" bindtap="submitTwentyMallBind">确认绑定</button>
      </view>
    </view>
  </view>
</view>
