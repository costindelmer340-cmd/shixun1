.hero {
  margin-bottom: 24rpx;
}

.platform-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.platform-card {
  display: flex;
  align-items: center;
  width: 48%;
  min-height: 210rpx;
  padding: 26rpx;
  margin-bottom: 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #eef2f7;
  box-sizing: border-box;
  flex-direction: column;
  text-align: center;
}

.platform-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 26rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
  background: #f2f4f7;
}

.platform-info {
  flex: none;
}

.arrow {
  display: none;
  color: #98a2b3;
  font-size: 42rpx;
}
