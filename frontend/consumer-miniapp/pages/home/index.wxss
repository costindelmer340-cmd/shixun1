.hero {
  margin-bottom: 24rpx;
}

.platform-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.platform-card {
  display: flex;
  align-items: center;
  width: 48%;
  min-height: 210rpx;
  padding: 26rpx;
  margin-bottom: 20rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #eef2f7;
  box-sizing: border-box;
  flex-direction: column;
  text-align: center;
}

.platform-main {
  display: flex;
  align-items: center;
  width: 100%;
  flex-direction: column;
}

.platform-card-wide {
  width: 100%;
  min-height: 0;
  flex-direction: column;
  align-items: stretch;
  text-align: left;
}

.platform-card-wide .platform-main {
  min-height: 120rpx;
  flex-direction: row;
}

.platform-card-wide .platform-icon {
  margin: 0 24rpx 0 0;
}

.platform-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 26rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
  background: #f2f4f7;
}

.platform-info {
  flex: 1;
  min-width: 0;
}

.arrow {
  display: none;
  color: #98a2b3;
  font-size: 42rpx;
}

.bind-btn {
  margin-left: auto;
  flex-shrink: 0;
  width: 140rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 12rpx;
  background: #1f7ae0;
  color: #fff;
  font-size: 26rpx;
}

.bound-panel {
  width: 100%;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2f7;
}

.bound-title {
  color: #667085;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.bound-account {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 58rpx;
  padding: 10rpx 14rpx;
  margin-bottom: 10rpx;
  border-radius: 12rpx;
  background: #f8fbff;
  color: #344054;
  font-size: 26rpx;
}

.unbind-btn {
  width: 104rpx;
  height: 48rpx;
  line-height: 48rpx;
  margin: 0;
  border-radius: 10rpx;
  background: #fff1f0;
  color: #d92d20;
  font-size: 22rpx;
}

.dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, 0.36);
  padding: 40rpx;
  box-sizing: border-box;
}

.dialog {
  width: 100%;
  border-radius: 20rpx;
  background: #fff;
  padding: 34rpx;
  box-sizing: border-box;
}

.dialog-input {
  height: 86rpx;
  border: 1rpx solid #d8e1ef;
  border-radius: 12rpx;
  padding: 0 22rpx;
  margin-top: 18rpx;
  box-sizing: border-box;
}

.dialog-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 26rpx;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.cancel-btn {
  background: #f2f4f7;
  color: #344054;
}

.confirm-btn {
  background: #1f7ae0;
  color: #fff;
}
